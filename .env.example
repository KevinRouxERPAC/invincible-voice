# =============================================================================
# InvincibleVoice — Modèle de configuration locale
# =============================================================================
# Copiez ce fichier en `.env` à la racine du dépôt, puis renseignez les valeurs.
#   cp .env.example .env        (bash)
#   Copy-Item .env.example .env (PowerShell)
#
# La voie recommandée pour démarrer est Gradium (STT/TTS cloud) + Cerebras (LLM) :
# elle ne nécessite pas de GPU et fonctionne avec les paliers gratuits.
# Créez un compte sur https://www.cerebras.ai/ et https://gradium.ai/.
#
# Ne JAMAIS committer le fichier `.env` (il contient vos clés secrètes).
# =============================================================================


# ---- LLM (obligatoire) ------------------------------------------------------
# Cerebras recommandé : faible latence, palier gratuit suffisant pour un usage
# personnel. Tout service compatible OpenAI fonctionne.
KYUTAI_LLM_URL=https://api.cerebras.ai/v1
KYUTAI_LLM_MODEL=qwen-3-235b-a22b-instruct-2507
KYUTAI_LLM_API_KEY=cle_cerebras_a_renseigner


# ---- STT / TTS via Gradium (voie cloud, recommandée) ------------------------
GRADIUM_API_KEY=cle_gradium_a_renseigner
TTS_SERVER=https://eu.api.gradium.ai/api/
TTS_IS_GRADIUM=true
KYUTAI_STT_URL=wss://eu.api.gradium.ai/api/speech/asr
STT_IS_GRADIUM=true

# Voix par défaut (identifiant de voix du catalogue Gradium).
# Défaut : Olivier (vMYQUSzm6GRkJX6d) — français, masculin, timbre friendly.
TTS_VOICE_ID=vMYQUSzm6GRkJX6d

# ---- STT / TTS via Kyutai (auto-hébergé, nécessite un GPU) -------------------
# Décommentez et renseignez si vous auto-hébergez les serveurs Kyutai.
# STT_IS_GRADIUM=false
# TTS_IS_GRADIUM=false
# TTS_SERVER=http://votre_serveur_tts:port
# KYUTAI_STT_URL=ws://votre_serveur_stt:port
# KYUTAI_API_KEY=cle_kyutai_si_requise


# ---- Authentification -------------------------------------------------------
# Clé secrète de signature des jetons JWT. Générez une longue chaîne aléatoire,
# par ex. : python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=remplacer_par_une_longue_chaine_aleatoire

# Connexion par e-mail + mot de passe. Laissez true pour la voie cloud simple
# (login Google désactivé si GOOGLE_CLIENT_ID est vide/REPLACE_ME).
ALLOW_PASSWORD=true

# Connexion Google OAuth (optionnel). Laissez REPLACE_ME pour la masquer.
# Renseignez un vrai Client ID Google pour activer le bouton « Se connecter avec Google ».
GOOGLE_CLIENT_ID=REPLACE_ME

# Compte anonyme partagé (sans authentification).
# DÉFAUT SÉCURISÉ : 0 (fermé). N'ouvrez (1) que sur un réseau privé/LAN de
# confiance — sinon profil et historique de conversations (données de santé)
# sont exposés sans authentification.
ALLOW_ANONYMOUS_USER=0


# ---- Sécurité (optionnel) ---------------------------------------------------
# Bearer token protégeant le endpoint Prometheus /metrics. Vide = non protégé
# (acceptable en local ; requis sur un backend public Cloud Run).
METRICS_TOKEN=

# Origines autorisées en CORS (séparées par des virgules). À renseigner quand
# la PWA (Firebase Hosting) appelle le backend (Cloud Run) sur un autre domaine.
# Exemple : https://votre-projet.web.app,https://votre-projet.firebaseapp.com
CORS_ALLOW_ORIGINS=

# Limite des tentatives d'authentification par IP (par minute).
AUTH_RATE_LIMIT_PER_MINUTE=10

# Utiliser Redis (partagé entre replicas) pour le rate-limit. En local mono-
# instance, laisser false (compteur en mémoire suffit).
RATE_LIMIT_USE_REDIS=false


# ---- Grafana (observabilité, optionnel) -------------------------------------
# Identifiants de l'interface Grafana (accessible sur /grafana).
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=remplacer_par_un_mot_de_passe


# ---- Ne pas modifier (câblage interne docker compose) -----------------------
# Les valeurs ci-dessous sont gérées par docker-compose.yml directement.
# KYUTAI_USERS_DATA_PATH=/users_data
# REDIS_HOST=redis
# REDIS_PORT=6379
